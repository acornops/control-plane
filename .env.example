# Standalone control-plane defaults. For full-platform local development, use
# ../acornops-deployment/env/local/.env.local instead.
PORT=8081
LOG_LEVEL=info
ENABLE_API_DOCS=true
TRUST_PROXY=false
CONTROL_PLANE_BASE_URL=http://localhost:8081
CONTROL_PLANE_INSTANCE_ID=
CONTROL_PLANE_DISTRIBUTED_ROUTING_ENABLED=false
CONTROL_PLANE_AGENT_OWNER_TTL_SECONDS=90
CONTROL_PLANE_AGENT_SNAPSHOT_INTERVAL_SECONDS=60
CORS_ORIGIN=*

SESSION_COOKIE_NAME=acornops_cp_session
SESSION_MAX_AGE_SECONDS=604800
SESSION_IDLE_TIMEOUT_SECONDS=86400
CSRF_SECRET=dev_csrf_secret_change_me_32_bytes_minimum
CONVERSATION_RETENTION_DAYS=30
CONVERSATION_RETENTION_JOB_INTERVAL_SECONDS=3600
RUN_EVENT_BUFFER_SIZE=200
PERSIST_RUN_EVENTS=false
SEED_DEVELOPMENT_DATA=true
SEED_AGENT_KEY=

OIDC_ISSUER_URL=http://localhost:8082/realms/acornops
OIDC_PUBLIC_ISSUER_URL=http://localhost:8082/realms/acornops
OIDC_PROVIDER_NAME=keycloak
OIDC_CLIENT_ID=acornops-control-plane
OIDC_CLIENT_SECRET=acornops-control-plane-secret
OIDC_TOKEN_ENDPOINT_AUTH_METHOD=client_secret_basic
OIDC_AUTHORIZATION_ENDPOINT_OVERRIDE=
OIDC_TOKEN_ENDPOINT_OVERRIDE=
OIDC_USERINFO_ENDPOINT_OVERRIDE=
OIDC_JWKS_URI_OVERRIDE=
OIDC_REDIRECT_URI=http://localhost:8081/api/v1/auth/oidc/callback
OIDC_SCOPES=openid profile email
OIDC_USE_USERINFO=true
OIDC_REQUIRE_VERIFIED_EMAIL=true

PASSWORD_AUTH_IDENTIFIER_MAX_ATTEMPTS=50
PASSWORD_EMAIL_VERIFICATION_REQUIRED=true
PASSWORD_EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
PASSWORD_EMAIL_VERIFICATION_RESEND_WINDOW_SECONDS=300
PASSWORD_SIGNUP_ALLOW_UNVERIFIED_EMAIL=false
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
PASSWORD_RESET_REQUEST_WINDOW_SECONDS=300
EMAIL_DELIVERY_MODE=log
EMAIL_DELIVERY_ALLOW_LOG_IN_PRODUCTION=false
EMAIL_FROM='AcornOps <noreply@localhost>'
EMAIL_PUBLIC_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true

ORCH_SERVICE_TOKEN=dev_orchestrator_token
EXECUTION_ENGINE_BASE_URL=http://localhost:8080
EXECUTION_ENGINE_DISPATCH_TOKEN=dev_execution_engine_dispatch_token
EXECUTION_ENGINE_TIMEOUT_MS=10000

DATABASE_URL=postgresql://acornops:acornops@localhost:5432/acornops_control_plane
REDIS_URL=redis://localhost:6379/0

LLM_GATEWAY_URL=http://localhost:8001
LLM_GATEWAY_ADMIN_TOKEN=dev_orchestrator_token
LLM_GATEWAY_TIMEOUT_MS=120000
LLM_DEFAULT_PROVIDER=gemini
LLM_DEFAULT_MODEL=gemini-2.0-flash
LLM_ALLOWED_PROVIDERS=openai,anthropic,gemini
LLM_ALLOWED_MODELS=gpt-4.1-mini,claude-3-5-sonnet-latest,gemini-2.0-flash
AGENT_SYSTEM_INSTRUCTION='You are AcornOps, a Kubernetes troubleshooting assistant. Use concise, safe recommendations and call available tools before answering questions about live cluster state.'
AGENT_CONTEXT_MAX_TOKENS=120000
AGENT_BUDGET_CENTS=25
AGENT_LLM_TEMPERATURE=0.2
AGENT_MAX_RUNTIME_MS=600000
AGENT_MAX_STEPS=16
AGENT_MAX_TOOL_CALLS=24
AGENT_MAX_DUPLICATE_TOOL_CALLS=2
AGENT_TOOL_DEFAULT_TIMEOUT_MS=10000
AGENT_WRITE_CONFIRMATION_REQUIRED=true
AGENT_WRITE_CONFIRMATION_TIMEOUT_SECONDS=300
QUOTA_MAX_WORKSPACE_MEMBERSHIPS=50
QUOTA_MAX_WORKSPACE_MEMBERS_PER_WORKSPACE=100
QUOTA_MAX_KUBERNETES_CLUSTERS_PER_WORKSPACE=30
QUOTA_MAX_VIRTUAL_MACHINES_PER_WORKSPACE=30
BUILTIN_MCP_SERVER_NAME=acornops-cluster-agent
BUILTIN_MCP_SERVER_URL=http://control-plane:8081/internal/v1/mcp
BUILTIN_MCP_SERVER_DISPLAY_NAME='AcornOps Kubernetes Tools'
GATEWAY_TOKEN_ISSUER=llm-gateway
GATEWAY_TOKEN_AUDIENCE=execution-gateway
GATEWAY_TOKEN_TTL_SECONDS=900
GATEWAY_SIGNING_KID=cp-rs256-1
GATEWAY_SIGNING_PRIVATE_KEY_PEM_B64=
GATEWAY_VERIFICATION_JWKS_JSON=
