################################################################################
# Standalone Control Plane
################################################################################

# For full-platform local development, use the deployment env file instead:
# ../acornops-deployment/env/local/.env.local
PORT=8081

################################################################################
# HTTP, Logging & Public URLs
################################################################################

LOG_LEVEL=info
ENABLE_API_DOCS=true
CONTROL_PLANE_BASE_URL=http://localhost:8081

################################################################################
# Routing, CORS & Proxy
################################################################################

MANAGEMENT_CONSOLE_BASE_URL=http://localhost:3000
TRUST_PROXY=false
CONTROL_PLANE_INSTANCE_ID=
CONTROL_PLANE_DISTRIBUTED_ROUTING_ENABLED=false
CONTROL_PLANE_AGENT_OWNER_TTL_SECONDS=90
CONTROL_PLANE_AGENT_SNAPSHOT_INTERVAL_SECONDS=60
CORS_ORIGIN=*

################################################################################
# Sessions & CSRF
################################################################################

SESSION_COOKIE_NAME=acornops_cp_session
SESSION_MAX_AGE_SECONDS=604800
SESSION_IDLE_TIMEOUT_SECONDS=86400
CSRF_SECRET=dev_csrf_secret_change_me_32_bytes_minimum

################################################################################
# Retention & Run Events
################################################################################

CONVERSATION_RETENTION_DAYS=30
CONVERSATION_RETENTION_JOB_INTERVAL_SECONDS=3600
TARGET_CHAT_REPORT_RETENTION_DAYS=30
RUN_EVENT_BUFFER_SIZE=200
PERSIST_RUN_EVENTS=false

################################################################################
# Feature Flags
################################################################################

TARGET_INSIGHTS_ENABLED=true

################################################################################
# Development Seed Data
################################################################################

SEED_DEVELOPMENT_DATA=true
SEED_AGENT_KEY=ak_local_dev_shared_key
SEED_VM_AGENT_KEY=ak_local_vm_dev_shared_key

################################################################################
# AgentK Installation
################################################################################

AGENTK_HELM_RELEASE_NAME=acornops-agentk
AGENTK_HELM_CHART_REF=oci://ghcr.io/acornops/charts/acornops-agentk
# Optional exact chart version. Leave blank to install the latest release,
# including experimental versions while AgentK remains pre-release.
AGENTK_HELM_CHART_VERSION=
AGENTK_HELM_NAMESPACE=acornops-agentk
# Optional JSON object of downstream AgentK chart values. Control-plane-owned
# identity, connectivity, namespace-scope, and write-mode values are rejected.
AGENTK_HELM_VALUES_JSON={}
# Optional path on the operator machine that runs the generated Helm command.
AGENTK_HELM_ADDITIONAL_CA_FILE_PATH=

################################################################################
# OIDC Authentication
################################################################################

OIDC_ENABLED=true
OIDC_ISSUER_URL=http://localhost:8082/realms/acornops
OIDC_PUBLIC_ISSUER_URL=http://localhost:8082/realms/acornops
OIDC_PROVIDER_NAME=keycloak
OIDC_CLIENT_ID=acornops-control-plane
OIDC_CLIENT_SECRET=acornops-control-plane-secret
OIDC_TOKEN_ENDPOINT_AUTH_METHOD=client_secret_basic
OIDC_AUTHORIZATION_ENDPOINT_OVERRIDE=
OIDC_TOKEN_ENDPOINT_OVERRIDE=
OIDC_USERINFO_ENDPOINT_OVERRIDE=
OIDC_JWKS_URI_OVERRIDE=
OIDC_END_SESSION_ENDPOINT_OVERRIDE=http://localhost:8082/realms/acornops/protocol/openid-connect/logout
OIDC_REDIRECT_URI=http://localhost:8081/api/v1/auth/oidc/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:8081/api/v1/auth/oidc/logout/callback
OIDC_SCOPES=openid profile email
OIDC_USE_USERINFO=true
OIDC_ADMISSION_POLICY_JSON={"requireVerifiedEmail":true}
# Explicit provider-subject mappings reconciled before the server accepts traffic.
# Do not use email as a substitute for the provider subject.
OIDC_PRELINKED_IDENTITIES_JSON=[]

################################################################################
# Outbound Webhooks
################################################################################

# Additive exceptions for operator-trusted webhook hostnames that resolve to
# RFC1918 IPv4, RFC6598 shared, or IPv6 unique-local addresses. Public webhook hosts remain
# available. Wildcards must use the form *.example.com and do not match the apex.
WEBHOOK_EGRESS_ALLOWED_PRIVATE_HOSTS_JSON=[]

################################################################################
# Password Auth & Email Delivery
################################################################################

PASSWORD_AUTH_IDENTIFIER_MAX_ATTEMPTS=50
PASSWORD_EMAIL_VERIFICATION_REQUIRED=true
PASSWORD_EMAIL_VERIFICATION_TOKEN_TTL_SECONDS=86400
PASSWORD_EMAIL_VERIFICATION_RESEND_WINDOW_SECONDS=300
PASSWORD_SIGNUP_ALLOW_UNVERIFIED_EMAIL=false
PASSWORD_RESET_ENABLED=true
PASSWORD_RESET_TOKEN_TTL_SECONDS=3600
PASSWORD_RESET_REQUEST_WINDOW_SECONDS=300
EMAIL_DELIVERY_MODE=log
EMAIL_DELIVERY_ALLOW_LOG_IN_PRODUCTION=false
EMAIL_FROM='AcornOps <noreply@localhost>'
EMAIL_PUBLIC_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true

################################################################################
# Execution Engine Integration
################################################################################

ORCH_SERVICE_TOKEN=dev_orchestrator_token
EXTERNAL_INTEGRATION_CLIENTS_JSON=[{"id":"dev-client","provider":"external","displayName":"Development external integration","sha256":"c900e895f6e7b6358dcfc3c6e0cc24d275f3c413256911756c5150dd9f9fe222"}]
EXTERNAL_INTEGRATION_LINK_TOKEN_TTL_SECONDS=600
EXTERNAL_INTEGRATION_LINK_TTL_SECONDS=2592000
EXTERNAL_INTEGRATION_LINK_TOKEN_RETENTION_DAYS=30
EXECUTION_ENGINE_BASE_URL=http://localhost:8080
EXECUTION_ENGINE_DISPATCH_TOKEN=dev_execution_engine_dispatch_token
EXECUTION_ENGINE_TIMEOUT_MS=10000

################################################################################
# Datastores
################################################################################

DATABASE_URL=postgresql://acornops:acornops@localhost:5432/acornops_control_plane
REDIS_URL=redis://localhost:6379/0

################################################################################
# LLM Gateway Integration
################################################################################

LLM_GATEWAY_URL=http://localhost:8001
LLM_GATEWAY_ADMIN_TOKEN=dev_orchestrator_token
LLM_GATEWAY_TIMEOUT_MS=120000

################################################################################
# LLM Policy
################################################################################

LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_MODEL=gpt-5.5
LLM_ALLOWED_PROVIDERS=openai,anthropic,gemini
LLM_ALLOWED_PROVIDER_MODELS=openai:gpt-5.5|gpt-5.4|gpt-5.4-mini|gpt-5.4-nano|gpt-5|gpt-5-mini|gpt-5-nano;anthropic:claude-fable-5|claude-opus-4-8|claude-sonnet-4-6|claude-haiku-4-5;gemini:gemini-3.5-flash|gemini-3.5-flash-lite|gemini-3.1-pro|gemini-3.1-flash|gemini-3.1-flash-lite|gemini-2.5-pro|gemini-2.5-flash|gemini-2.5-flash-lite|gemini-2.0-flash|gemini-2.0-flash-lite
LLM_ALLOWED_REASONING_EFFORTS=off,low,medium,high

################################################################################
# AI Assistant Runtime Defaults
################################################################################

ASSISTANT_CONTEXT_MAX_TOKENS=120000
ASSISTANT_BUDGET_CENTS=25
ASSISTANT_LLM_TEMPERATURE=0.2
ASSISTANT_MAX_RUNTIME_MS=600000
ASSISTANT_MAX_STEPS=16
ASSISTANT_MAX_TOOL_CALLS=24
ASSISTANT_MAX_DUPLICATE_TOOL_CALLS=2
ASSISTANT_TOOL_DEFAULT_TIMEOUT_MS=10000
ASSISTANT_WRITE_CONFIRMATION_REQUIRED=true
ASSISTANT_WRITE_CONFIRMATION_TIMEOUT_SECONDS=900

################################################################################
# Workspace Quotas
################################################################################

QUOTA_MAX_WORKSPACE_MEMBERSHIPS=50
QUOTA_MAX_WORKSPACE_MEMBERS_PER_WORKSPACE=100
QUOTA_MAX_KUBERNETES_CLUSTERS_PER_WORKSPACE=30
QUOTA_MAX_VIRTUAL_MACHINES_PER_WORKSPACE=30

################################################################################
# Built-in Target MCP Bridge
################################################################################

BUILTIN_TARGET_MCP_SERVER_NAME=acornops-target-agent
BUILTIN_TARGET_MCP_SERVER_URL=http://control-plane:8081/internal/v1/mcp

################################################################################
# Gateway Token Signing
################################################################################

GATEWAY_TOKEN_ISSUER=llm-gateway
GATEWAY_TOKEN_AUDIENCE=execution-gateway
GATEWAY_TOKEN_TTL_SECONDS=900
GATEWAY_SIGNING_KID=cp-rs256-1
GATEWAY_SIGNING_PRIVATE_KEY_PEM_B64=
GATEWAY_VERIFICATION_JWKS_JSON=
