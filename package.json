{
  "name": "acornops-control-plane",
  "version": "0.0.1-experimental.1",
  "private": true,
  "description": "AcornOps control plane (Node.js + Express + TypeScript)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "NODE_ENV=test node --import tsx --test --test-concurrency=1 test/*.test.ts test/**/*.test.ts",
    "test:coverage": "NODE_ENV=test c8 --reporter=text --reporter=lcov --reporter=cobertura node --import tsx --test --test-concurrency=1 test/*.test.ts test/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "style:check": "bash scripts/check-style.sh",
    "db:migrate": "tsx src/scripts/control-plane-db.ts migrate",
    "db:status": "tsx src/scripts/control-plane-db.ts status",
    "db:check": "tsx src/scripts/control-plane-db.ts check",
    "capabilities:preflight": "tsx src/scripts/control-plane-db.ts capabilities:preflight",
    "migrations:check": "node scripts/check-db-migrations.mjs",
    "authz:check": "node scripts/check-authz.mjs",
    "membership:check": "node scripts/check-workspace-membership.mjs",
    "run-events:check": "node scripts/check-run-event-durability.mjs",
    "contracts:check": "node scripts/check-contracts.mjs",
    "openapi:check": "node --import tsx scripts/check-public-openapi.mjs",
    "openapi:export": "node --import tsx scripts/export-public-openapi.mjs",
    "harness:check": "node scripts/check-harness.mjs",
    "validate": "npm run typecheck && npm run style:check && npm run test && npm run migrations:check && npm run authz:check && npm run membership:check && npm run run-events:check && npm run contracts:check && npm run openapi:check && npm run harness:check && npm run build",
    "validate:ci": "npm run typecheck && npm run style:check && npm run test:coverage && npm run migrations:check && npm run authz:check && npm run membership:check && npm run run-events:check && npm run contracts:check && npm run openapi:check && npm run harness:check && npm run build"
  },
  "dependencies": {
    "@types/nodemailer": "^8.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "nodemailer": "^8.0.10",
    "pg": "^8.13.3",
    "pino": "^9.7.0",
    "swagger-ui-dist": "5.32.8",
    "uuid": "^11.1.0",
    "ws": "^8.20.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.11.11",
    "@types/ws": "^8.5.14",
    "c8": "^11.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scarfSettings": {
    "enabled": false
  }
}
