{
  "repo": "control-plane",
  "version": 1,
  "runtimeDependencies": ["management-console", "execution-engine", "llm-gateway", "k8s-agent", "vm-agent"],
  "counterparts": {
    "management-console": {
      "authPaths": [
        "GET /api/v1/auth/oidc/login?return_to=<management-console-url>",
