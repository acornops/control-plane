{
  "repo": "control-plane",
  "version": 1,
  "executionContractVersion": 2,
  "runtimeDependencies": [
    "management-console",
    "execution-engine",
    "llm-gateway",
    "agentk",
    "agentv"
  ],
  "counterparts": {
    "management-console": {
      "authContract": {
        "config": "GET /api/v1/auth/config returns the real OIDC capability flag and never exposes admission policy.",
        "logout": "POST /api/v1/auth/logout returns {status=ok,mode=oidc|local,redirectPath}; redirectPath is an AcornOps path and never a provider URL.",
        "browserResults": ["auth_result=oidc_access_denied", "logout_result=success", "logout_result=local_only", "logout_result=incomplete"]
      },
      "workflowCapabilityCeiling": {
        "rule": "A workflow selects one or more active reviewed specialist Agents. restrictionMode=inherit resolves their current combined ceiling at session creation; restrictionMode=restrict requires semanticCapabilityIds to be an explicit subset.",
        "emptyRestrictionSemantics": "inherit requires an empty semanticCapabilityIds array. restrict may use an empty array to intentionally authorize no semantic capabilities. The console sends restrictionMode explicitly and stored definitions always contain the final field.",
        "agentOnlyAdditions": [
          "mcp_servers",
          "mcp_tools",
          "skills"
        ],
        "runtimeToolIdentity": "McpToolRef{serverId,toolName}"
      },
      "workflowRuntimePolicy": {
        "authority": "ASSISTANT_MAX_RUNTIME_MS is the only workflow execution limit and TARGET_CHAT_REPORT_RETENTION_DAYS is the only workflow and target-chat report retention policy.",
        "mutationContract": "Workflow mutations reject maxRuntimeSeconds, retentionDays, and all other unknown capability-policy fields; deployment policy is authoritative.",
        "response": "Workflow responses normalize maxRuntimeSeconds and retentionDays to effective deployment values.",
        "options": "Workflow option catalogs expose one effective runtime limit and one effective retention policy.",
        "manualDefaults": "When omitted, the server defaults manual workflows to read_only, inherit, workspace_metadata, read_workspace_data, and no approval requirements."
      },
      "workflowCapabilityPreview": {
        "path": "POST /api/v1/workflows/{workflowId}/capabilities-preview",
        "authorization": "Requires workspace-data read and the workflow mode's run-creation capability.",
        "snapshot": "Target candidates, mappings, and Agent registrations are evaluated from one request snapshot. The selected target is reloaded and its stored target type is authoritative.",
        "statuses": [
          "needs_target",
          "ready",
          "blocked"
        ],
        "targetStatuses": [
          "ready",
          "unavailable",
          "unsupported"
        ],
        "mcpAuthRequirements": "Every credentialed MCP server in the compiled Agent scope emits mcpRequirements[].{serverId,serverName,authType,owningAgent.{id,name},connectionState,authRequirement.{scope,credentialLabel,requiredInformation[].{name,description}},action}; generic connection metadata and guidance only, never provider profiles, URLs, headers, or credential values",
        "privacy": "Responses expose bounded reason codes and explicit capability-preview metadata only; compiled scopes, credentials, URLs, headers, tool arguments, input schemas, private connection state, and internal coordinator identity are excluded.",
        "mutation": "Preview creates no session, execution, run, approval, or audit record. Dispatch recompiles an internal authoritative scope that is never returned by the public API."
      },
      "workspaceNativeToolContract": {
        "catalog": [
          "prompt.resources.read",
          "http.fetch.get",
          "reports.pdf.generate"
        ],
        "modelAliases": {
          "prompt.resources.read": "_acornops_read_prompt_resources",
          "http.fetch.get": "acornops_fetch",
          "reports.pdf.generate": "acornops_generate_pdf_report"
        },
        "ownership": "Control-plane code owns workspace-native metadata, schemas, authorization class, audit operation, and execution.",
        "assignment": "manage_agents grants, updates, or revokes a tool on a specialist Agent and transactionally rebinds exact reviewed mappings and dependent readiness; optional code-validated config is accepted on PUT, revoke clears config, and bodyless grants remain valid for unconfigured tools; manage_mcp is not required.",
        "invocationScopePolicy": "Workspace-native declarations carry invocationScopes. prompt.resources.read and http.fetch.get support workflow; reports.pdf.generate supports workflow and target_chat; delegated specialist Workflow runs receive no workspace-native tools.",
        "artifactSafety": "reports.pdf.generate is a control-plane-owned internal_artifact available to workflows and target chat without crossing the target-adapter boundary. It is allowed in read-only runs without write approval, persisted as a write audit event, bounded, provenance-linked, authenticated, and idempotent by workflow run or target run plus tool_call_id.",
        "promptResources": "prompt.resources.read accepts binding IDs only and dispatches bounded reads through the providers authorized in the run's signed resource bindings.",
        "fetchSafety": "http.fetch.get accepts only a concrete url and executes unauthenticated public HTTPS GET in the control plane against one to 20 run-snapshotted full-URL patterns. Wildcards are restricted to path/query. DNS is public-only and pinned, redirects and IP literals are blocked, timeout is 15 seconds, decompressed output is capped at 256 KiB, and only JSON or text is returned as untrusted external data. Audits and metrics omit full URLs, queries, and bodies.",
        "ui": "Agent Capabilities > Tools lists AcornOps native tools separately from MCP-discovered tools. Fetch configuration uses a GET-only repeatable full-URL drawer; grant, configuration update, and revoke require manage_agents only.",
        "workflowUi": "Create defaults to inheritance after Agent selection. Advanced restriction supports narrowed and intentionally empty sets; review and readiness copy distinguish policy from effective capabilities.",
        "artifactUi": "Workflow and target-chat assistant responses expose authenticated PDF download cards returned by reports.pdf.generate; Copy remains a separate response action."
      },
      "workflowRoutingContract": {
        "request": "required unique non-empty agentIds; strict schema rejects every unknown field with INVALID_REQUEST",
        "response": "executionMode is derived as direct for one selected Agent or coordinated for two or more; selection order has no meaning",
        "coordinationTrace": "GET workflow execution returns only bounded child capability, target, specialist, status, and failure; internal coordinator identity and sensitive execution content are omitted",
        "cancellation": "parent cancellation cascades to active coordinated child runs"
      },
      "systemAutomationDefinitions": {
        "provisioning": "The greenfield baseline creates only the final schema. Current-version workspace provisioning atomically commits the two automatic specialist Agents, their two active workflows, and a completed starter installation. Opt-in definitions are installed explicitly; coordinated workflows use a versioned code-owned coordinator profile and create no hidden Agent.",
        "attribution": "Template-origin Agents and workflows are labeled as system provided and retain their template ID and version.",
        "visibility": "Every public Agent is a specialist capability profile. Public workflow, compiled-scope, audit, search, and trace DTOs omit internal coordinator profile instructions and identity.",
        "mutation": "Visible template-origin definitions accept availability-status changes, supported external bindings, duplication, and deletion. Definition edits and version restore remain immutable; Agent deletion returns structured dependent workflows until those dependencies are removed.",
        "duplication": "manage_agents or manage_workflows may copy the effective definition into a manual draft without capability installations, history, executions, schedules, sessions, or activity."
      },
      "catalogAuthorization": {
        "manageSources": "manage_catalog_sources",
        "installAgentMcp": [
          "manage_agents",
          "manage_mcp"
        ],
        "installTargetMcp": "manage_mcp",
        "installAgentSkills": [
          "manage_agents",
          "manage_skills"
